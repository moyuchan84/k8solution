# ─────────────────────────────────────────────
# 앱 기본 설정
# ─────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ─────────────────────────────────────────────
# 데이터베이스
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://platform:localdev@postgres:5432/gitops_platform
REDIS_URL=redis://redis:6379/0

# ─────────────────────────────────────────────
# GitHub Enterprise
# ─────────────────────────────────────────────
GITHUB_BASE_URL=https://github.samsungds.net
GITHUB_TOKEN=your-github-pat-here
GITHUB_ORG=your-org-name

# ─────────────────────────────────────────────
# Harbor 컨테이너 레지스트리
# ─────────────────────────────────────────────
HARBOR_URL=https://harbor.foundrymtc.samsungds.net
HARBOR_USERNAME=your-harbor-username
HARBOR_PASSWORD=your-harbor-password

# ─────────────────────────────────────────────
# ArgoCD
# ─────────────────────────────────────────────
ARGOCD_SERVER=https://argocd.swsol.samsungds.net
ARGOCD_TOKEN=your-argocd-token

# ─────────────────────────────────────────────
# GitOps 저장소
# ─────────────────────────────────────────────
GITOPS_REPO=github.samsungds.net/infra-team/gitops-manifests
GITOPS_BRANCH=main
DOMAIN_SUFFIX=swsol.samsungds.net

# ─────────────────────────────────────────────
# Kubernetes
# ─────────────────────────────────────────────
# 로컬 개발: false, 클러스터 내부 배포: true
K8S_IN_CLUSTER=false
# kubeconfig 경로 (K8S_IN_CLUSTER=false 일 때). 비워두면 Mock 모드
K8S_KUBECONFIG=

# ─────────────────────────────────────────────
# 인증 (JWT / OIDC / LDAP)
# ─────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production-use-long-random-string

OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

LDAP_SERVER=
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=
LDAP_BASE_DN=

# ─────────────────────────────────────────────
# LLM 연동 (선택적 — 처음엔 false 로 시작)
# ─────────────────────────────────────────────
LLM_ENABLED=false

# 로컬 개발: Ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3.2:3b
LLM_API_KEY=ollama

# 사내 배포 시 아래로 교체
# LLM_BASE_URL=https://llm-api.samsungds.net/v1
# LLM_MODEL=gpt-oss-12b
# LLM_API_KEY=your-internal-api-key

# ─────────────────────────────────────────────
# ARC (GitHub Actions Runner Controller)
# ─────────────────────────────────────────────
ARC_NAMESPACE=arc-systems
ARC_RUNNER_NAMESPACE_PREFIX=arc-runners
